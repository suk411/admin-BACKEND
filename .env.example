# ==========================================
# Admin Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in values

# Server
PORT=5000
NODE_ENV=development

# MongoDB (same as main backend - shares the same database)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/backend-ledger?retryWrites=true&w=majority

# WinGo Separate MongoDB
WINGO_MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/wingoreal?retryWrites=true&w=majority

# Redis (same as main backend)
REDIS_URL=redis://default:password@redis-host:port

# Admin JWT Secret (dedicated admin auth - separate from user JWT_SECRET)
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# Fallback: needed for verifying user tokenVersion if re-using user JWT
JWT_SECRET=your_user_jwt_secret_here

# CORS (comma-separated origins)
CORS_ORIGINS=https://admin.example.com,http://localhost:3000

# ==========================================
# Payment Gateways (for withdrawal payouts)
# ==========================================

# SimplyPay
SIMPLYPAY_APP_ID=your_app_id
SIMPLYPAY_SECRET_KEY=your_secret_key
SIMPLYPAY_BASE_URL=https://api.paysimply.net/api/v2/payment/order/create
SIMPLYPAY_PAYOUT_NOTIFY_URL=https://your-admin-backend.com/api/admin/payment/payout-callback

# UPay
UPAY_MERCHANT_ID=your_merchant_id
UPAY_MERCHANT_KEY=your_merchant_key
UPAY_BASE_URL=https://open.rplapi.com/rupeeLink/api
UPAY_PAYOUT_CALLBACK_URL=https://your-admin-backend.com/api/admin/payment/upay-payout-callback

# GSPay
GSPAY_AUTH_KEY=your_auth_key
GSPAY_SECRET_KEY=your_secret_key
GSPAY_BASE_URL=https://api2.gspay.gold
GSPAY_PAYOUT_CALLBACK_URL=https://your-admin-backend.com/api/admin/payment/gspay-payout-callback

# ==========================================
# Game Provider (for admin move-game-to-wallet)
# ==========================================
GAME_API_URL=http://gsmd.336699bet.com
OPERATOR_CODE=i4bi
GAME_SECRET_KEY=your_game_secret_key
